# ---------------------------------------------------------
# FLASK CONFIGURATION
# ---------------------------------------------------------
# Generate a random secret key for session security.
# You can generate one using Python: 
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ---------------------------------------------------------
# GOOGLE OAUTH CONFIGURATION
# ---------------------------------------------------------
# Leave these empty if you only want Local Registration.
# If filled, you must configure them in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ---------------------------------------------------------
# DATABASE CONFIGURATION
# ---------------------------------------------------------
# Default is SQLite in the same folder
DATABASE_URI=
